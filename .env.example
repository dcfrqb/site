# ============================================================
# CRS VPN Site — переменные окружения
# Скопируйте в .env и заполните
# ============================================================

# ─── Shared с vpn-bot ───────────────────────────────────────
# (те же значения что в vpn-bot/.env)

DATABASE_URL=postgresql+asyncpg://crs_user:crs_pass@localhost:5432/crs_vpn
REDIS_URL=redis://localhost:6379/0

YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_API_KEY=your_api_key
YOOKASSA_RETURN_URL=https://vpn.example.com/dashboard?payment=success
YOOKASSA_WEBHOOK_SECRET=your_webhook_secret

REMNA_API_BASE=https://your-remna-panel.internal
REMNA_API_KEY=your_remna_api_key
SUBSCRIPTION_BASE_URL=https://sub.vpn.example.com

BOT_TOKEN=your_telegram_bot_token
ADMINS=123456789,987654321

# ─── Web-specific ───────────────────────────────────────────

# JWT секрет (минимум 32 символа, случайный!)
JWT_SECRET=change-this-to-a-long-random-string-in-production

# Telegram Bot username (без @) для Login Widget
TELEGRAM_BOT_USERNAME=your_bot_username

# CORS (URL вашего сайта)
CORS_ORIGINS=https://vpn.example.com

# ─── Docker ─────────────────────────────────────────────────

# Порт HTTP (Nginx)
HTTP_PORT=80

# Порт web-api (если нужен прямой доступ)
WEB_API_PORT=8002

# Docker network из vpn-bot docker-compose
VPN_DOCKER_NETWORK=crs-vpn-bot_default

# Путь к vpn-bot/src (для volume mount shared кода)
VPN_BOT_SRC=../vpn-bot/src
